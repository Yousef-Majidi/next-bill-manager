{
	"name": "next-bill-manager",
	"version": "0.3.0",
	"private": true,
	"packageManager": "pnpm@10.11.0",
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:coverage:check": "vitest run --coverage",
		"test:coverage:html": "vitest run --coverage --reporter=html",
		"test:coverage:lcov": "vitest run --coverage",
		"check-dependencies": "node scripts/check-dependencies.mjs",
		"validate-structure": "node scripts/validate-feature-structure.mjs",
		"validate-exports": "node scripts/validate-barrel-exports.mjs",
		"test-code-organization": "node scripts/test-code-organization.mjs",
		"validate-all": "pnpm run validate-structure && pnpm run validate-exports && pnpm run check-dependencies && pnpm run test-code-organization",
		"quality-check": "pnpm run lint && pnpm run test:coverage:check && pnpm run validate-all",
		"quality-gate": "node scripts/quality-gate.mjs",
		"quality-gate:full": "pnpm run quality-check && pnpm run build && pnpm run quality-gate",
		"pre-commit": "pnpm run validate-all",
		"prepare": "husky",
		"db:migrate": "node scripts/migrate.mjs scripts/migrations/migrate-consolidated-bills.mjs",
		"db:backup": "node scripts/migrate.mjs scripts/migrations/backup-all-collections.mjs",
		"db:restore": "node scripts/migrate.mjs scripts/migrations/restore-all-collections.mjs",
		"db:diagnose": "node scripts/migrate.mjs scripts/migrations/diagnose-all-collections.mjs",
		"db:demo:setup": "node scripts/migrate.mjs scripts/migrations/create-demo-user-data.mjs",
		"version:patch": "npm version patch",
		"version:minor": "npm version minor",
		"version:major": "npm version major",
		"version:preview": "npm version prerelease --preid=beta",
		"release:prepare": "pnpm run quality-check && pnpm run build && pnpm run version:patch",
		"release:minor": "pnpm run quality-check && pnpm run build && pnpm run version:minor",
		"release:major": "pnpm run quality-check && pnpm run build && pnpm run version:major"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"prettier --write"
		],
		"*.{json,md,yml,yaml}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"@radix-ui/react-avatar": "^1.1.11",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slider": "^1.3.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@vercel/analytics": "^1.5.0",
		"autoprefixer": "^10.4.21",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.2.3",
		"googleapis": "^149.0.0",
		"jotai": "^2.15.1",
		"lucide-react": "^0.511.0",
		"mongodb": "^6.20.0",
		"next": "15.5.6",
		"next-auth": "^4.24.13",
		"next-themes": "^0.4.6",
		"postcss": "^8.5.6",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-hook-form": "^7.66.0",
		"sanitize-html": "^2.17.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.4.0",
		"zod": "^3.25.76"
	},
	"pnpm": {
		"overrides": {
			"playwright": ">=1.55.1"
		}
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.1",
		"@next/eslint-plugin-next": "^16.0.1",
		"@tailwindcss/postcss": "^4.1.17",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.1",
		"@trivago/prettier-plugin-sort-imports": "^5.2.2",
		"@types/node": "^20.19.24",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"@types/sanitize-html": "^2.16.0",
		"@typescript-eslint/eslint-plugin": "^8.46.3",
		"@typescript-eslint/parser": "^8.46.3",
		"@vitejs/plugin-react": "^5.1.0",
		"@vitest/browser": "^4.0.8",
		"@vitest/coverage-v8": "^4.0.8",
		"@vitest/ui": "^4.0.8",
		"eslint": "^9.39.1",
		"eslint-config-next": "16.0.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-filename-rules": "^1.3.1",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.4",
		"eslint-plugin-react-hooks": "^5.2.0",
		"glob": "^10.4.5",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"lint-staged": "^16.2.6",
		"mongodb-memory-server": "^10.3.0",
		"msw": "^2.12.1",
		"prettier": "^3.6.2",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"shadcn": "^2.10.0",
		"tailwindcss": "^4.1.17",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.8"
	}
}
